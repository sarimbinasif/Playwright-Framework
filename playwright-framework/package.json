{
  "name": "playwright-automation-framework",
  "version": "1.0.0",
  "description": "Playwright + JS automation framework with POM, data-driven testing, hooks, and Allure reporting",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "pretest": "node -e \"const fs=require('fs');if(!fs.existsSync('allure-results'))fs.mkdirSync('allure-results');fs.copyFileSync('environment.properties','allure-results/environment.properties');fs.copyFileSync('categories.json','allure-results/categories.json');\"",
    "report": "allure generate ./allure-results --clean -o ./allure-report && allure open ./allure-report",
    "report:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "clean": "rm -rf allure-results allure-report test-results screenshots"
  },
  "keywords": ["playwright", "automation", "pom", "javascript"],
  "author": "Your Name",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "allure-playwright": "^2.15.1",
    "allure-commandline": "^2.27.0",
    "fast-xml-parser": "^4.4.0",
    "winston": "^3.13.0",
    "dotenv": "^16.4.5"
  }
}
